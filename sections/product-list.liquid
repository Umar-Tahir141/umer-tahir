{% liquid
  assign collection = section.settings.collection
%}

<section
  class="tisso-vision"
  data-section-id="{{ section.id }}"
  data-section-type="tisso-vision"
>
  <div class="tisso-vision__wrapper">

    {%- if section.settings.title != blank -%}
      <h2 class="tisso-vision__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="tisso-vision__grid">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.product_count -%}
          {%- assign featured_image = product.featured_image -%}
          <div class="tisso-vision__item">
            <a href="{{ product.url }}" class="tisso-vision__image-link" aria-label="{{ product.title | escape }}">
              {%- if featured_image != blank -%}
                <img
                  src="{{ featured_image | image_url: width: 900 }}"
                  srcset="
                    {{ featured_image | image_url: width: 400 }} 400w,
                    {{ featured_image | image_url: width: 600 }} 600w,
                    {{ featured_image | image_url: width: 900 }} 900w
                  "
                  sizes="(max-width: 520px) 50vw, 25vw"
                  alt="{{ featured_image.alt | default: product.title | escape }}"
                  width="{{ featured_image.width }}"
                  height="{{ featured_image.height }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'tisso-vision__placeholder' }}
              {%- endif -%}
            </a>

            <button
              class="tisso-vision__plus-btn"
              aria-label="{{ 'sections.tisso_vision.view_product' | t: title: product.title }}"
              data-product-id="{{ product.id }}"
              data-product-title="{{ product.title | escape }}"
              data-product-url="{{ product.url }}"
              data-product-price="{{ product.price | money }}"
              data-product-compare-price="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | money }}{% endif %}"
              data-product-image="{% if featured_image != blank %}{{ featured_image | image_url: width: 400 }}{% endif %}"
              data-product-image-alt="{{ featured_image.alt | default: product.title | escape }}"
              data-product-available="{{ product.available }}"
              data-product-variants="{{ product.variants | json | escape }}"
              type="button"
            >
              <span aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.product_count) -%}
          <div class="tisso-vision__item tisso-vision__item--placeholder">
            {{ 'product-' | append: i | placeholder_svg_tag: 'tisso-vision__placeholder' }}
            <button class="tisso-vision__plus-btn" type="button" disabled aria-hidden="true">
              <span aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<!-- Product Popup Modal -->
<div
  class="tisso-vision__popup-overlay"
  id="TissoVisionPopup-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'sections.tisso_vision.popup_label' | t }}"
  hidden
>
  <div class="tisso-vision__popup">
    <button
      class="tisso-vision__popup-close"
      aria-label="{{ 'accessibility.close' | t }}"
      type="button"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="2" y1="2" x2="14" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="14" y1="2" x2="2" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="tisso-vision__popup-image-wrap">
      <img
        class="tisso-vision__popup-img"
        src=""
        alt=""
        width="400"
        height="400"
        loading="lazy"
      >
    </div>

    <div class="tisso-vision__popup-body">
      <p class="tisso-vision__popup-title"></p>
      <div class="tisso-vision__popup-price-wrap">
        <span class="tisso-vision__popup-price"></span>
        <s class="tisso-vision__popup-compare-price"></s>
      </div>
      <a class="tisso-vision__popup-view-btn" href="#">
        {{ 'sections.tisso_vision.view_product_btn' | t | default: 'View Product' }}
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
/* =========================================
   Tisso Vision in the Wild — Section Styles
   ========================================= */

.tisso-vision {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.tisso-vision__wrapper {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-padding, 20px);
}

/* Title */
.tisso-vision__title {
  font-family: 'Lustria', serif;
  font-weight: 400;
  font-size: 36px;
  line-height: 120%;
  letter-spacing: 0px;
  margin: 0 0 20px 0;
  color: currentColor;
}

/* Grid */
.tisso-vision__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px;
}

/* Grid Item */
.tisso-vision__item {
  position: relative;
  overflow: hidden;
  aspect-ratio: 433 / 444;
  background: #e5e0d8;
}

.tisso-vision__item img,
.tisso-vision__item .tisso-vision__placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.tisso-vision__image-link {
  display: block;
  width: 100%;
  height: 100%;
}

.tisso-vision__image-link img {
  transition: transform 0.4s ease;
}

.tisso-vision__item:hover .tisso-vision__image-link img {
  transform: scale(1.04);
}

/* Plus button */
.tisso-vision__plus-btn {
  position: absolute;
  bottom: 16px;
  right: 16px;
  width: 28px;
  height: 28px;
  background: #ffffff;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #111111;
  padding: 0;
  transition: transform 0.2s ease, background 0.2s ease;
  z-index: 2;
  box-shadow: 0 1px 4px rgba(0,0,0,0.18);
}

.tisso-vision__plus-btn:hover {
  transform: scale(1.15);
  background: #f0f0f0;
}

.tisso-vision__plus-btn:disabled {
  opacity: 0.4;
  cursor: default;
}

/* =========================================
   Popup Overlay
   ========================================= */

.tisso-vision__popup-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  box-sizing: border-box;
}

.tisso-vision__popup-overlay[hidden] {
  display: none;
}

.tisso-vision__popup {
  background: #ffffff;
  border-radius: 12px;
  width: 100%;
  max-width: 360px;
  position: relative;
  overflow: hidden;
  animation: tissoFadeUp 0.22s ease;
}

@keyframes tissoFadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tisso-vision__popup-close {
  position: absolute;
  top: 12px;
  right: 12px;
  background: rgba(255,255,255,0.85);
  border: none;
  border-radius: 50%;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #111;
  z-index: 3;
  transition: background 0.15s;
}

.tisso-vision__popup-close:hover {
  background: #f0f0f0;
}

.tisso-vision__popup-image-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #e5e0d8;
  overflow: hidden;
}

.tisso-vision__popup-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.tisso-vision__popup-body {
  padding: 16px 20px 20px;
}

.tisso-vision__popup-title {
  font-size: 16px;
  font-weight: 500;
  margin: 0 0 8px 0;
  color: #111111;
  line-height: 1.3;
}

.tisso-vision__popup-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-bottom: 16px;
}

.tisso-vision__popup-price {
  font-size: 15px;
  font-weight: 600;
  color: #111111;
}

.tisso-vision__popup-compare-price {
  font-size: 13px;
  color: #999999;
  text-decoration: line-through;
}

.tisso-vision__popup-compare-price:empty {
  display: none;
}

.tisso-vision__popup-view-btn {
  display: block;
  width: 100%;
  padding: 12px 16px;
  background: #111111;
  color: #ffffff;
  text-align: center;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  border-radius: 6px;
  letter-spacing: 0.02em;
  transition: background 0.2s;
  box-sizing: border-box;
}

.tisso-vision__popup-view-btn:hover {
  background: #333333;
}

/* =========================================
   Mobile — 2 columns, 170×186px ratio
   ========================================= */

@media (max-width: 520px) {
  .tisso-vision__title {
    font-size: 28px;
  }

  .tisso-vision__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .tisso-vision__item {
    aspect-ratio: 170 / 186;
  }

  .tisso-vision__plus-btn {
    width: 24px;
    height: 24px;
    bottom: 10px;
    right: 10px;
  }

  .tisso-vision__plus-btn svg {
    width: 11px;
    height: 11px;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  const sectionId = '{{ section.id }}';
  const overlay = document.getElementById('TissoVisionPopup-' + sectionId);
  if (!overlay) return;

  const popupImg     = overlay.querySelector('.tisso-vision__popup-img');
  const popupTitle   = overlay.querySelector('.tisso-vision__popup-title');
  const popupPrice   = overlay.querySelector('.tisso-vision__popup-price');
  const popupCompare = overlay.querySelector('.tisso-vision__popup-compare-price');
  const popupLink    = overlay.querySelector('.tisso-vision__popup-view-btn');
  const closeBtn     = overlay.querySelector('.tisso-vision__popup-close');

  function openPopup(btn) {
    const title        = btn.dataset.productTitle || '';
    const price        = btn.dataset.productPrice || '';
    const comparePrice = btn.dataset.productComparePrice || '';
    const imgSrc       = btn.dataset.productImage || '';
    const imgAlt       = btn.dataset.productImageAlt || title;
    const url          = btn.dataset.productUrl || '#';

    popupTitle.textContent      = title;
    popupPrice.textContent      = price;
    popupCompare.textContent    = comparePrice;
    popupLink.href              = url;

    if (imgSrc) {
      popupImg.src = imgSrc;
      popupImg.alt = imgAlt;
      popupImg.style.display = 'block';
    } else {
      popupImg.style.display = 'none';
    }

    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closePopup() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  // Plus buttons
  document.querySelectorAll(
    '[data-section-id="' + sectionId + '"] .tisso-vision__plus-btn'
  ).forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openPopup(btn);
    });
  });

  // Close on X button
  closeBtn.addEventListener('click', closePopup);

  // Close on overlay click
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closePopup();
  });

  // Close on Escape key
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) {
      closePopup();
    }
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Tisso Vision in the Wild",
  "tag": "section",
  "class": "tisso-vision-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Tisso Vision in the Wild",
      "category": "Products"
    }
  ]
}
{% endschema %}
