{% liquid
  assign max_items = section.settings.max_products
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}


<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lustria&display=swap" rel="stylesheet">

<style>
  #tisso-vision-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #tisso-vision-{{ section.id }} .tv__wrapper {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  #tisso-vision-{{ section.id }} .tv__title {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    margin: 0 0 20px 0;
    color: currentColor;
  }

  #tisso-vision-{{ section.id }} .tv__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  #tisso-vision-{{ section.id }} .tv__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 433 / 444;
    background: #e5e0d8;
  }

  #tisso-vision-{{ section.id }} .tv__item a {
    display: block;
    width: 100%;
    height: 100%;
  }

  #tisso-vision-{{ section.id }} .tv__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  #tisso-vision-{{ section.id }} .tv__item:hover img {
    transform: scale(1.04);
  }

  #tisso-vision-{{ section.id }} .tv__item svg.placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #tisso-vision-{{ section.id }} .tv__plus {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 28px;
    height: 28px;
    background: #ffffff;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111111;
    padding: 0;
    z-index: 2;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    transition: transform 0.2s ease;
  }

  #tisso-vision-{{ section.id }} .tv__plus:hover {
    transform: scale(1.15);
  }

  /* Popup */
  #tisso-popup-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
  }

  #tisso-popup-{{ section.id }}[hidden] {
    display: none;
  }

  #tisso-popup-{{ section.id }} .tv__popup {
    background: #ffffff;
    border-radius: 12px;
    width: 100%;
    max-width: 360px;
    position: relative;
    overflow: hidden;
    animation: tvssFadeUp 0.22s ease;
  }

  @keyframes tvssFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #tisso-popup-{{ section.id }} .tv__popup-close {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(255,255,255,0.9);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    z-index: 3;
  }

  #tisso-popup-{{ section.id }} .tv__popup-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #e5e0d8;
    overflow: hidden;
  }

  #tisso-popup-{{ section.id }} .tv__popup-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #tisso-popup-{{ section.id }} .tv__popup-body {
    padding: 16px 20px 20px;
  }

  #tisso-popup-{{ section.id }} .tv__popup-title {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 6px 0;
    color: #111111;
    line-height: 1.3;
  }

  #tisso-popup-{{ section.id }} .tv__popup-prices {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 16px;
  }

  #tisso-popup-{{ section.id }} .tv__popup-price {
    font-size: 15px;
    font-weight: 600;
    color: #111111;
  }

  #tisso-popup-{{ section.id }} .tv__popup-compare {
    font-size: 13px;
    color: #999999;
    text-decoration: line-through;
  }

  #tisso-popup-{{ section.id }} .tv__popup-compare:empty {
    display: none;
  }

  #tisso-popup-{{ section.id }} .tv__popup-btn {
    display: block;
    width: 100%;
    padding: 12px 16px;
    background: #111111;
    color: #ffffff;
    text-align: center;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border-radius: 6px;
    box-sizing: border-box;
    transition: background 0.2s;
  }

  #tisso-popup-{{ section.id }} .tv__popup-btn:hover {
    background: #333333;
    color: #ffffff;
  }

  @media (max-width: 520px) {
    #tisso-vision-{{ section.id }} .tv__title {
      font-size: 28px;
    }

    #tisso-vision-{{ section.id }} .tv__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3px;
    }

    #tisso-vision-{{ section.id }} .tv__item {
      aspect-ratio: 170 / 186;
    }

    #tisso-vision-{{ section.id }} .tv__plus {
      width: 24px;
      height: 24px;
      bottom: 8px;
      right: 8px;
    }

    #tisso-vision-{{ section.id }} .tv__plus svg {
      width: 10px;
      height: 10px;
    }
  }
</style>

<section id="tisso-vision-{{ section.id }}">
  <div class="tv__wrapper">

    {%- if section.settings.title != blank -%}
      <h2 class="tv__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="tv__grid">
      {%- assign collection = section.settings.collection -%}
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.product_count -%}
          <div class="tv__item">
            <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  srcset="
                    {{ product.featured_image | image_url: width: 400 }} 400w,
                    {{ product.featured_image | image_url: width: 600 }} 600w,
                    {{ product.featured_image | image_url: width: 900 }} 900w
                  "
                  sizes="(max-width: 520px) 50vw, 25vw"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>

            <button
              class="tv__plus"
              type="button"
              aria-label="Quick view {{ product.title | escape }}"
              data-title="{{ product.title | escape }}"
              data-price="{{ product.price | money }}"
              data-compare="{%- if product.compare_at_price > product.price -%}{{ product.compare_at_price | money }}{%- endif -%}"
              data-url="{{ product.url }}"
              data-img="{%- if product.featured_image != blank -%}{{ product.featured_image | image_url: width: 400 }}{%- endif -%}"
              data-img-alt="{{ product.featured_image.alt | default: product.title | escape }}"
            >
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.product_count) -%}
          <div class="tv__item">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            <button class="tv__plus" type="button" aria-hidden="true" disabled>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<!-- Popup Modal -->
<div id="tisso-popup-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Product quick view" hidden>
  <div class="tv__popup">
    <button class="tv__popup-close" type="button" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="tv__popup-img-wrap">
      <img class="tv__popup-img" src="" alt="" width="400" height="400">
    </div>
    <div class="tv__popup-body">
      <p class="tv__popup-title"></p>
      <div class="tv__popup-prices">
        <span class="tv__popup-price"></span>
        <s class="tv__popup-compare"></s>
      </div>
      <a class="tv__popup-btn" href="#">View Product</a>
    </div>
  </div>
</div>

<script>
(function () {
  var sectionId = '{{ section.id }}';
  var section   = document.getElementById('tisso-vision-' + sectionId);
  var overlay   = document.getElementById('tisso-popup-' + sectionId);
  if (!section || !overlay) return;

  var popupImg     = overlay.querySelector('.tv__popup-img');
  var popupTitle   = overlay.querySelector('.tv__popup-title');
  var popupPrice   = overlay.querySelector('.tv__popup-price');
  var popupCompare = overlay.querySelector('.tv__popup-compare');
  var popupLink    = overlay.querySelector('.tv__popup-btn');
  var closeBtn     = overlay.querySelector('.tv__popup-close');

  function openPopup(btn) {
    popupTitle.textContent   = btn.dataset.title || '';
    popupPrice.textContent   = btn.dataset.price || '';
    popupCompare.textContent = btn.dataset.compare || '';
    popupLink.href           = btn.dataset.url || '#';

    if (btn.dataset.img) {
      popupImg.src            = btn.dataset.img;
      popupImg.alt            = btn.dataset.imgAlt || '';
      popupImg.style.display  = 'block';
    } else {
      popupImg.style.display = 'none';
    }

    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closePopup() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  section.querySelectorAll('.tv__plus').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openPopup(btn);
    });
  });

  closeBtn.addEventListener('click', closePopup);

  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closePopup();
  });
})();
</script>

{% schema %}
{
  "name": "Tisso Vision in the Wild",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Tisso Vision in the Wild"
    }
  ]
}
{% endschema %}
