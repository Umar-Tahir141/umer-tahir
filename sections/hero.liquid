{% liquid
  assign media_count = 0
  assign media_count_mobile = 0
  assign fallback_to_desktop = false
  assign media_1 = 'none'
  assign media_2 = 'none'
  assign media_1_mobile = 'none'
  assign media_2_mobile = 'none'
  assign has_only_video = false
  assign has_only_video_mobile = false

  if section.settings.image_1 != blank and section.settings.media_type_1 == 'image'
    assign media_1 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_1 != blank and section.settings.media_type_1 == 'video'
    assign media_1 = 'video'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.image_2 != blank and section.settings.media_type_2 == 'image'
    assign media_2 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_2 != blank and section.settings.media_type_2 == 'video'
    assign media_2 = 'video'
    assign media_count = media_count | plus: 1
  endif

  if section.settings.custom_mobile_media
    if section.settings.image_1_mobile != blank and section.settings.media_type_1_mobile == 'image'
      assign media_1_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_1_mobile != blank and section.settings.media_type_1_mobile == 'video'
      assign media_1_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.image_2_mobile != blank and section.settings.media_type_2_mobile == 'image'
      assign media_2_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_2_mobile != blank and section.settings.media_type_2_mobile == 'video'
      assign media_2_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
  endif

  if media_count > 0 and media_1 != 'image' and media_2 != 'image'
    assign has_only_video = true
  endif
  if media_count > 0 and media_count_mobile > 0 and media_1_mobile != 'image' and media_2_mobile != 'image'
    assign has_only_video_mobile = true
  endif

  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  if section.settings.custom_mobile_media == false or media_count_mobile == 0 or media_count == 0
    assign media_count_mobile = media_count
    assign fallback_to_desktop = true
  endif
%}

{%- liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id, skip_contrast: true
  endif
-%}

<style>
  #Hero-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
  }
  #Hero-{{ section.id }} .hero-custom__top,
  #Hero-{{ section.id }} .hero-custom__bottom,
  #Hero-{{ section.id }} .hero-custom__text,
  #Hero-{{ section.id }} .hero-custom__right {
    background-color: transparent;
  }
</style>

<div
  id="Hero-{{ section.id }}"
  class="hero-custom{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>

  {%- comment -%} ═══════════════ DESKTOP (unchanged) ═══════════════ {%- endcomment -%}
  <div class="hero-custom__desktop">
    {%- comment -%} ── ROW 1: Full-width top image ── {%- endcomment -%}
    <div class="hero-custom__top">
      {%- if media_1 == 'image' -%}
        {{
          section.settings.image_1
          | image_url: width: 3840
          | image_tag:
            width: section.settings.image_1.width,
            widths: widths,
            height: section.settings.image_1.height,
            alt: section.settings.image_1.alt,
            class: 'hero-custom__top-img',
            sizes: '100vw',
            fetchpriority: fetch_priority,
            data-testid: 'hero-desktop-image-1'
        }}
      {%- elsif media_1 == 'video' -%}
        {{
          section.settings.video_1
          | video_tag:
            poster: nil,
            autoplay: true,
            loop: true,
            controls: false,
            muted: true,
            class: 'hero-custom__top-img',
            data-testid: 'hero-desktop-video-1'
        }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-custom__top-img' }}
      {%- endif -%}
    </div>

    {%- comment -%} ── ROW 2: Text left + image_2 right ── {%- endcomment -%}
    <div class="hero-custom__bottom">
      <div class="hero-custom__text">
        <div
          class="
            hero-custom__content-inner
            layout-panel-flex
            layout-panel-flex--{{ section.settings.content_direction }}
            {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
            section-content-wrapper
          "
          style="{% render 'layout-panel-style', settings: section.settings %}"
        >
          {%- if section.settings.heading != blank -%}
            <h2 class="hero-custom__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <p class="hero-custom__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <a 
              href="{{ section.settings.button_link | default: '#' }}" 
              class="hero-custom__button"
              {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
            >
              <span class="hero-custom__button-text">{{ section.settings.button_label }}</span>
              <span class="hero-custom__button-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          {%- endif -%}

          {% content_for 'blocks' %}
        </div>
      </div>

      <div class="hero-custom__right">
        {%- if media_2 == 'image' -%}
          {{
            section.settings.image_2
            | image_url: width: 1920
            | image_tag:
              width: section.settings.image_2.width,
              widths: widths,
              height: section.settings.image_2.height,
              alt: section.settings.image_2.alt,
              class: 'hero-custom__right-img',
              sizes: '50vw',
              fetchpriority: 'auto',
              data-testid: 'hero-desktop-image-2'
          }}
        {%- elsif media_2 == 'video' -%}
          {{
            section.settings.video_2
            | video_tag:
              poster: nil,
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              class: 'hero-custom__right-img',
              data-testid: 'hero-desktop-video-2'
          }}
        {%- else -%}
          {{ 'hero-apparel-2' | placeholder_svg_tag: 'hero-custom__right-img' }}
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ═══════════════ MOBILE (pixel-perfect) ═══════════════ {%- endcomment -%}
  <div class="hero-custom__mobile">
    <div class="hero-custom__mobile-inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="hero-custom__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero-custom__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="hero-custom__mobile-media">
        {%- liquid
          assign mobile_banner = section.settings.image_1
          if section.settings.custom_mobile_media and section.settings.image_1_mobile != blank
            assign mobile_banner = section.settings.image_1_mobile
          endif
        -%}

        {%- if media_1 == 'image' -%}
          {{
            mobile_banner
            | image_url: width: 1200
            | image_tag:
              width: mobile_banner.width,
              widths: mobile_widths,
              height: mobile_banner.height,
              alt: mobile_banner.alt,
              class: 'hero-custom__mobile-img',
              sizes: '100vw',
              loading: 'lazy'
          }}
        {%- elsif media_1 == 'video' -%}
          {{
            section.settings.video_1
            | video_tag:
              poster: nil,
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              class: 'hero-custom__mobile-img'
          }}
        {%- else -%}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-custom__mobile-img' }}
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a 
          href="{{ section.settings.button_link | default: '#' }}" 
          class="hero-custom__button hero-custom__button--mobile"
          {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
        >
          <span>{{ section.settings.button_label }}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.bottom_text != blank -%}
        <p class="hero-custom__bottom-text">{{ section.settings.bottom_text }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.link != blank -%}
    <a
      href="{{ section.settings.link }}"
      class="hero-custom__link"
      {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
    ></a>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── WRAPPER ── */
  .hero-custom {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .hero-custom[data-shopify-visual-preview] {
    min-height: 600px;
  }

  /* ── DESKTOP ONLY ── */
  .hero-custom__desktop {
    display: flex;
    flex-direction: column;
  }

  .hero-custom__mobile {
    display: none;
  }

  /* ── ROW 1: full-width top image ── */
  .hero-custom__top {
    width: 100%;
    line-height: 0;
    overflow: hidden;
  }

  .hero-custom__top-img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── ROW 2: bottom row ── */
  .hero-custom__bottom {
    display: grid;
    grid-template-columns: 480px 1fr;
    min-height: 340px;
  }

  /* ── LEFT: text / content blocks ── */
  .hero-custom__text {
    padding: 27px 30px 52px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    border-right: 1px solid #e8e8e8;
    position: relative;
    z-index: 1;
  }

  .hero-custom__content-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
  }

  /* ── HEADING ── */
  .hero-custom__heading {
    font-size: 45px;
    font-weight: 600;
    line-height: 1.3;
    color: #000000;
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* ── SUBHEADING ── */
  .hero-custom__subheading {
    font-size: 14px;
    line-height: 1.5;
    color: #333333;
    margin: 0;
  }

  /* ── BUTTON ── */
  .hero-custom__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    background-color: #000000;
    color: #ffffff;
    text-decoration: none;
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    margin-top: 8px;
    min-width: 200px;
    max-width: 100%;
  }

  .hero-custom__button:hover {
    background-color: #333333;
  }

  .hero-custom__button-text {
    flex: 1;
    text-align: center;
  }

  .hero-custom__button-arrow {
    display: flex;
    align-items: center;
    margin-left: 12px;
    flex-shrink: 0;
  }

  .hero-custom__button-arrow svg {
    width: 18px;
    height: 18px;
  }

  /* ── RIGHT: image_2 ── */
  .hero-custom__right {
    overflow: hidden;
    line-height: 0;
    position: relative;
  }

  .hero-custom__right-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  /* ── section-wide link overlay ── */
  .hero-custom__link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  /* ── MOBILE (matches reference image) ── */
  @media screen and (max-width: 749px) {
    .hero-custom__desktop {
      display: none;
    }

    .hero-custom__mobile {
      display: block;
    }

    .hero-custom__mobile-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 40px 24px 32px;
    }

    .hero-custom__mobile .hero-custom__heading {
      font-size: 32px;
      font-weight: 600;
      line-height: 1.2;
      color: #000000;
      margin: 0 0 12px 0;
      letter-spacing: -0.02em;
    }

    .hero-custom__mobile .hero-custom__subheading {
      font-size: 14px;
      line-height: 1.5;
      color: #333333;
      margin: 0 0 28px 0;
      max-width: 300px;
    }

    .hero-custom__mobile-media {
      width: 100%;
      margin-bottom: 24px;
      line-height: 0;
    }

    .hero-custom__mobile-img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }

    .hero-custom__button--mobile {
      width: 100%;
      margin: 0 0 20px 0;
      min-width: unset;
      justify-content: center;
      gap: 12px;
      height: 48px;
      padding: 0 20px;
    }

    .hero-custom__bottom-text {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666666;
      margin: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "blocks": [
    { "type": "@theme" },
    { "type": "text" },
    { "type": "button" },
    { "type": "logo" },
    { "type": "jumbo-text" },
    { "type": "spacer" },
    { "type": "group" },
    { "type": "_marquee" }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.media_1"
    },
    {
      "type": "select",
      "id": "media_type_1",
      "label": "t:settings.type",
      "options": [
        { "value": "image", "label": "t:options.image" },
        { "value": "video", "label": "t:options.video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_1 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.media_type_1 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.media_2"
    },
    {
      "type": "select",
      "id": "media_type_2",
      "label": "t:settings.type",
      "options": [
        { "value": "image", "label": "t:options.image" },
        { "value": "video", "label": "t:options.video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_2 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.media_type_2 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.mobile_media"
    },
    {
      "type": "checkbox",
      "id": "stack_media_on_mobile",
      "label": "t:settings.stack_media_on_mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_media",
      "label": "t:settings.custom_mobile_media",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.mobile_media_1",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "select",
      "id": "media_type_1_mobile",
      "label": "t:settings.type",
      "options": [
        { "value": "image", "label": "t:options.image" },
        { "value": "video", "label": "t:options.video" }
      ],
      "default": "image",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "image_picker",
      "id": "image_1_mobile",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1_mobile",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_1_mobile == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.mobile_media_2",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "select",
      "id": "media_type_2_mobile",
      "label": "t:settings.type",
      "options": [
        { "value": "image", "label": "t:options.image" },
        { "value": "video", "label": "t:options.video" }
      ],
      "default": "image",
      "visible_if": "{{ section.settings.custom_mobile_media }}"
    },
    {
      "type": "image_picker",
      "id": "image_2_mobile",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_2_mobile == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_2_mobile",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.custom_mobile_media and section.settings.media_type_2_mobile == 'video' }}"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "t:content.section_link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        { "value": "column", "label": "t:options.vertical" },
        { "value": "row", "label": "t:options.horizontal" }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" },
        { "value": "space-between", "label": "t:options.space_between" }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        { "value": "flex-start", "label": "t:options.top" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.bottom" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "checkbox",
      "id": "align_baseline",
      "label": "t:settings.align_baseline",
      "default": false,
      "visible_if": "{{ section.settings.vertical_alignment == 'flex-end' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        { "value": "flex-start", "label": "t:options.top" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.bottom" },
        { "value": "space-between", "label": "t:options.space_between" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
