<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lustria&display=swap" rel="stylesheet">

<style>
  #tisso-vision-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #tisso-vision-{{ section.id }} .tv__wrapper {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }
  #tisso-vision-{{ section.id }} .tv__title {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    margin: 0 0 20px 0;
    color: currentColor;
  }
  #tisso-vision-{{ section.id }} .tv__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }
  #tisso-vision-{{ section.id }} .tv__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 433 / 444;
    background: #e5e0d8;
    display: block;
  }
  #tisso-vision-{{ section.id }} .tv__item a {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0; left: 0;
  }
  #tisso-vision-{{ section.id }} .tv__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  #tisso-vision-{{ section.id }} .tv__item:hover img {
    transform: scale(1.04);
  }
  #tisso-vision-{{ section.id }} .tv__plus {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 28px;
    height: 28px;
    background: #ffffff;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111111;
    padding: 0;
    z-index: 3;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    transition: transform 0.2s ease;
  }
  #tisso-vision-{{ section.id }} .tv__plus:hover {
    transform: scale(1.15);
  }

  /* ─── POPUP OVERLAY ─── */
  #tisso-popup-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
  }
  #tisso-popup-{{ section.id }}[hidden] {
    display: none;
  }

  /* ─── POPUP CARD ─── */
  #tisso-popup-{{ section.id }} .tv__popup {
    background: #ffffff;
    width: 100%;
    max-width: 400px;
    position: relative;
    overflow: hidden;
    animation: tvssFadeUp 0.22s ease;
    padding: 24px;
    box-sizing: border-box;
  }
  @keyframes tvssFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Close button */
  #tisso-popup-{{ section.id }} .tv__popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    z-index: 3;
    padding: 0;
    transition: transform 0.2s ease;
  }
  #tisso-popup-{{ section.id }} .tv__popup-close:hover {
    transform: scale(1.1);
  }

  /* Top row: image + info */
  #tisso-popup-{{ section.id }} .tv__popup-layout {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
  }
  #tisso-popup-{{ section.id }} .tv__popup-image-wrap {
    width: 120px;
    height: 140px;
    flex-shrink: 0;
    background: #f5f5f5;
    overflow: hidden;
  }
  #tisso-popup-{{ section.id }} .tv__popup-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #tisso-popup-{{ section.id }} .tv__popup-info {
    flex: 1;
    min-width: 0;
  }
  #tisso-popup-{{ section.id }} .tv__popup-title {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 6px 0;
    color: #111111;
    line-height: 1.3;
  }
  #tisso-popup-{{ section.id }} .tv__popup-price {
    font-size: 18px;
    font-weight: 600;
    color: #111111;
    margin-bottom: 8px;
  }
  #tisso-popup-{{ section.id }} .tv__popup-desc {
    font-size: 13px;
    color: #666666;
    line-height: 1.5;
    margin: 0;
  }

  /* Variants */
  #tisso-popup-{{ section.id }} .tv__popup-variants {
    margin-bottom: 4px;
  }
  #tisso-popup-{{ section.id }} .tv__popup-label {
    display: block;
    font-size: 13px;
    color: #666666;
    margin-bottom: 8px;
    font-weight: 400;
  }

  /* Color toggle */
  #tisso-popup-{{ section.id }} .tv__popup-colors {
    margin-bottom: 16px;
  }
  #tisso-popup-{{ section.id }} .tv__color-options {
    display: flex;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn {
    flex: 1;
    height: 42px;
    border: 1px solid #e0e0e0;
    background: #ffffff;
    color: #111111;
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    position: relative;
    margin-left: -1px;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn:first-child {
    margin-left: 0;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn.is-selected {
    border-left: 3px solid #1a3c8e;
    border-color: #111111;
    z-index: 1;
    font-weight: 500;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn:hover {
    border-color: #111111;
    z-index: 2;
  }

  /* Size dropdown */
  #tisso-popup-{{ section.id }} .tv__popup-sizes {
    margin-bottom: 20px;
  }
  #tisso-popup-{{ section.id }} .tv__size-select-wrap {
    position: relative;
  }
  #tisso-popup-{{ section.id }} .tv__size-select {
    width: 100%;
    height: 44px;
    border: 1px solid #e0e0e0;
    padding: 0 40px 0 12px;
    font-size: 14px;
    color: #111111;
    background: #ffffff;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    font-family: inherit;
    border-radius: 0;
  }
  #tisso-popup-{{ section.id }} .tv__size-select:focus {
    outline: none;
    border-color: #111111;
  }
  #tisso-popup-{{ section.id }} .tv__size-arrow {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #111111;
    width: 12px;
    height: 12px;
  }

  /* Add to cart */
  #tisso-popup-{{ section.id }} .tv__popup-addtocart {
    width: 100%;
    height: 48px;
    background: #111111;
    color: #ffffff;
    border: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    font-family: inherit;
    transition: background 0.2s;
  }
  #tisso-popup-{{ section.id }} .tv__popup-addtocart:hover {
    background: #333333;
  }
  #tisso-popup-{{ section.id }} .tv__popup-addtocart:disabled {
    background: #999999;
    cursor: not-allowed;
  }
  #tisso-popup-{{ section.id }} .tv__cart-arrow {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #ffffff;
    width: 18px;
    height: 18px;
  }

  /* Error */
  #tisso-popup-{{ section.id }} .tv__popup-error {
    margin-top: 10px;
    font-size: 13px;
    color: #d32f2f;
    text-align: center;
    min-height: 18px;
  }

  @media screen and (max-width: 749px) {
    #tisso-vision-{{ section.id }} .tv__title {
      font-size: 24px !important;
    }
    #tisso-vision-{{ section.id }} .tv__grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 3px !important;
    }
    #tisso-vision-{{ section.id }} .tv__item {
      aspect-ratio: 170 / 186 !important;
    }
    #tisso-vision-{{ section.id }} .tv__plus {
      width: 22px !important;
      height: 22px !important;
      bottom: 6px !important;
      right: 6px !important;
    }
    #tisso-vision-{{ section.id }} .tv__plus svg {
      width: 10px !important;
      height: 10px !important;
    }
    #tisso-popup-{{ section.id }} .tv__popup {
      padding: 20px;
    }
  }
</style>

{%- liquid
  assign tv_collection = section.settings.collection
  assign tv_count = section.settings.product_count
-%}

<section id="tisso-vision-{{ section.id }}">
  <div class="tv__wrapper">

    {%- if section.settings.title != blank -%}
      <h2 class="tv__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="tv__grid">

      {%- if tv_collection != blank -%}
        {%- for product in tv_collection.products limit: tv_count -%}

          {%- assign p_img = product.featured_image -%}
          {%- assign p_img_url = '' -%}
          {%- if p_img != blank -%}
            {%- assign p_img_url = p_img | image_url: width: 900 -%}
            {%- assign p_img_url_sm = p_img | image_url: width: 400 -%}
            {%- assign p_img_url_md = p_img | image_url: width: 600 -%}
          {%- endif -%}

          {%- assign p_compare = '' -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign p_compare = product.compare_at_price | money -%}
          {%- endif -%}

          <div class="tv__item">
            {%- if p_img != blank -%}
              <img
                src="{{ p_img_url }}"
                srcset="{{ p_img_url_sm }} 400w, {{ p_img_url_md }} 600w, {{ p_img_url }} 900w"
                sizes="(max-width: 520px) 50vw, 25vw"
                alt="{{ p_img.alt | default: product.title | escape }}"
                width="{{ p_img.width }}"
                height="{{ p_img.height }}"
                loading="lazy"
              >
            {%- endif -%}

            <a href="{{ product.url }}" aria-label="{{ product.title | escape }}"></a>

            <button
              class="tv__plus"
              type="button"
              aria-label="Quick view {{ product.title | escape }}"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | escape }}"
              data-price="{{ product.price | money }}"
              data-compare="{{ p_compare }}"
              data-url="{{ product.url }}"
              data-img="{{ p_img_url_sm }}"
              data-img-alt="{{ p_img.alt | default: product.title | escape }}"
            >
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

        {%- else -%}
          <p style="padding:20px;color:#999;">No products found in this collection.</p>
        {%- endfor -%}

      {%- else -%}
        <p style="padding:20px;color:#999;">Please select a collection in the theme editor.</p>
      {%- endif -%}

    </div>
  </div>
</section>

{%- comment -%} ===== PIXEL-PERFECT QUICK-VIEW POPUP ===== {%- endcomment -%}
<div id="tisso-popup-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Product quick view" hidden>
  <div class="tv__popup">

    {%- comment -%} Close X {%- endcomment -%}
    <button class="tv__popup-close" type="button" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    {%- comment -%} Image (120×140) + Title / Price / Desc {%- endcomment -%}
    <div class="tv__popup-layout">
      <div class="tv__popup-image-wrap">
        <img class="tv__popup-img" src="" alt="" width="120" height="140" loading="lazy">
      </div>
      <div class="tv__popup-info">
        <h3 class="tv__popup-title"></h3>
        <div class="tv__popup-price"></div>
        <p class="tv__popup-desc"></p>
      </div>
    </div>

    {%- comment -%} Color toggle + Size dropdown {%- endcomment -%}
    <div class="tv__popup-variants">
      <div class="tv__popup-colors" style="display:none;">
        <span class="tv__popup-label">Color</span>
        <div class="tv__color-options"></div>
      </div>

      <div class="tv__popup-sizes" style="display:none;">
        <span class="tv__popup-label">Size</span>
        <div class="tv__size-select-wrap">
          <select class="tv__size-select">
            <option value="">Choose your size</option>
          </select>
          <svg class="tv__size-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>

    {%- comment -%} Add to Cart {%- endcomment -%}
    <button class="tv__popup-addtocart" type="button">
      <span>ADD TO CART</span>
      <svg class="tv__cart-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M3 9H15M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="tv__popup-error" role="alert"></div>
  </div>
</div>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var section = document.getElementById('tisso-vision-' + sid);
  var overlay = document.getElementById('tisso-popup-' + sid);
  if (!section || !overlay) return;

  var popupImg      = overlay.querySelector('.tv__popup-img');
  var popupTitle    = overlay.querySelector('.tv__popup-title');
  var popupPrice    = overlay.querySelector('.tv__popup-price');
  var popupDesc     = overlay.querySelector('.tv__popup-desc');
  var colorSection  = overlay.querySelector('.tv__popup-colors');
  var colorContainer= overlay.querySelector('.tv__color-options');
  var sizeSection   = overlay.querySelector('.tv__popup-sizes');
  var sizeSelect    = overlay.querySelector('.tv__size-select');
  var addToCartBtn  = overlay.querySelector('.tv__popup-addtocart');
  var closeBtn      = overlay.querySelector('.tv__popup-close');
  var errorDiv      = overlay.querySelector('.tv__popup-error');

  var currentProduct = null;
  var selectedColor  = null;
  var selectedSize   = null;

  function formatMoney(cents) {
    return (cents / 100).toFixed(2).replace('.', ',') + '€';
  }

  function stripHtml(html) {
    if (!html) return '';
    return html.replace(/<<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
  }

  function getOptionIndex(options, name) {
    for (var i = 0; i < options.length; i++) {
      if (options[i].toLowerCase() === name.toLowerCase()) return i;
    }
    return -1;
  }

  function resetButton() {
    addToCartBtn.disabled = false;
    addToCartBtn.innerHTML = '<span>ADD TO CART</span>' +
      '<svg class="tv__cart-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">' +
      '<path d="M3 9H15M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }

  function openPopup(btn) {
    var handle = btn.dataset.handle;
    if (!handle) return;

    selectedColor = null;
    selectedSize  = null;
    errorDiv.textContent = '';
    resetButton();

    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';

    fetch('/products/' + handle + '.js')
      .then(function(res) {
        if (!res.ok) throw new Error('Network response was not ok');
        return res.json();
      })
      .then(function(product) {
        currentProduct = product;
        renderPopup(product);
      })
      .catch(function(err) {
        console.error('Quick view error:', err);
        errorDiv.textContent = 'Failed to load product details.';
      });

    closeBtn.focus();
  }

  function renderPopup(product) {
    popupTitle.textContent = product.title;
    popupPrice.textContent = formatMoney(product.price);

    var desc = stripHtml(product.description);
    if (desc.length > 180) desc = desc.substring(0, 180) + '…';
    popupDesc.textContent = desc;

    if (product.image) {
      popupImg.src = product.image;
      popupImg.alt = product.title;
      popupImg.style.display = 'block';
    } else if (product.images && product.images.length > 0) {
      popupImg.src = product.images[0];
      popupImg.alt = product.title;
      popupImg.style.display = 'block';
    } else {
      popupImg.style.display = 'none';
    }

    /* ── Variants ── */
    colorContainer.innerHTML = '';
    sizeSelect.innerHTML = '<option value="">Choose your size</option>';
    colorSection.style.display = 'none';
    sizeSection.style.display  = 'none';

    if (!product.variants || product.variants.length === 0) return;

    var options = product.options || [];
    var colorIdx = getOptionIndex(options, 'Color');
    var sizeIdx  = getOptionIndex(options, 'Size');

    if (colorIdx === -1 && options.length > 0) colorIdx = 0;
    if (sizeIdx  === -1 && options.length > 1) sizeIdx  = 1;
    if (sizeIdx === colorIdx && options.length > 1) sizeIdx = 1;

    /* Colors */
    if (colorIdx !== -1) {
      var colors = [];
      product.variants.forEach(function(v) {
        var val = v['option' + (colorIdx + 1)];
        if (val && colors.indexOf(val) === -1) colors.push(val);
      });

      if (colors.length > 0) {
        colorSection.style.display = 'block';
        colors.forEach(function(color, index) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'tv__color-btn' + (index === 0 ? ' is-selected' : '');
          btn.textContent = color;
          btn.dataset.color = color;
          if (index === 0) selectedColor = color;

          btn.addEventListener('click', function() {
            colorContainer.querySelectorAll('.tv__color-btn').forEach(function(b) {
              b.classList.remove('is-selected');
            });
            btn.classList.add('is-selected');
            selectedColor = color;
          });

          colorContainer.appendChild(btn);
        });
      }
    }

    /* Sizes */
    if (sizeIdx !== -1) {
      var sizes = [];
      product.variants.forEach(function(v) {
        var val = v['option' + (sizeIdx + 1)];
        if (val && sizes.indexOf(val) === -1) sizes.push(val);
      });

      if (sizes.length > 0) {
        sizeSection.style.display = 'block';
        sizes.forEach(function(size) {
          var opt = document.createElement('option');
          opt.value = size;
          opt.textContent = size;
          sizeSelect.appendChild(opt);
        });

        sizeSelect.addEventListener('change', function() {
          selectedSize = this.value;
        });
      }
    }
  }

  function findVariant() {
    if (!currentProduct || !currentProduct.variants) return null;
    var options = currentProduct.options || [];
    var colorIdx = getOptionIndex(options, 'Color');
    var sizeIdx  = getOptionIndex(options, 'Size');

    if (colorIdx === -1 && options.length > 0) colorIdx = 0;
    if (sizeIdx  === -1 && options.length > 1) sizeIdx  = 1;
    if (sizeIdx === colorIdx && options.length > 1) sizeIdx = 1;

    for (var i = 0; i < currentProduct.variants.length; i++) {
      var v = currentProduct.variants[i];
      var match = true;

      if (colorIdx !== -1 && selectedColor) {
        if (v['option' + (colorIdx + 1)] !== selectedColor) match = false;
      }
      if (sizeIdx !== -1 && selectedSize) {
        if (v['option' + (sizeIdx + 1)] !== selectedSize) match = false;
      }
      if (colorIdx === -1 && sizeIdx === -1) return v; // single variant
      if (match) return v;
    }
    return null;
  }

  function addToCart() {
    errorDiv.textContent = '';
    var options = currentProduct ? currentProduct.options || [] : [];
    var hasColor = getOptionIndex(options, 'Color') !== -1 || (options.length > 0 && getOptionIndex(options, 'Color') === 0);
    var hasSize  = getOptionIndex(options, 'Size')  !== -1 || options.length > 1;

    if (hasColor && !selectedColor) {
      errorDiv.textContent = 'Please select a color.';
      return;
    }
    if (hasSize && !selectedSize) {
      errorDiv.textContent = 'Please select a size.';
      return;
    }

    var variant = findVariant();
    if (!variant) {
      errorDiv.textContent = 'Selected combination is not available.';
      return;
    }

    addToCartBtn.disabled = true;
    addToCartBtn.innerHTML = '<span>Adding…</span>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variant.id, quantity: 1 })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Add to cart failed');
      return res.json();
    })
    .then(function() {
      addToCartBtn.innerHTML = '<span>ADDED!</span>';
      setTimeout(function() {
        resetButton();
        closePopup();
      }, 1000);
    })
    .catch(function(err) {
      console.error(err);
      errorDiv.textContent = 'Could not add to cart. Please try again.';
      resetButton();
    });
  }

  function closePopup() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
    currentProduct = null;
    selectedColor  = null;
    selectedSize   = null;
  }

  /* ── Event wiring ── */
  section.querySelectorAll('.tv__plus').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      openPopup(btn);
    });
  });

  closeBtn.addEventListener('click', closePopup);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closePopup();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closePopup();
  });
  addToCartBtn.addEventListener('click', addToCart);
})();
</script>

{% schema %}
{
  "name": "Tisso Vision in the Wild",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
