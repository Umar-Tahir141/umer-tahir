<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lustria&display=swap" rel="stylesheet">

<style>
  #tisso-vision-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #tisso-vision-{{ section.id }} .tv__wrapper {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }
  #tisso-vision-{{ section.id }} .tv__title {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    margin: 0 0 20px 0;
    color: currentColor;
  }
  #tisso-vision-{{ section.id }} .tv__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }
  #tisso-vision-{{ section.id }} .tv__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 433 / 444;
    background: #e5e0d8;
    display: block;
  }
  #tisso-vision-{{ section.id }} .tv__item a {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0; left: 0;
  }
  #tisso-vision-{{ section.id }} .tv__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  #tisso-vision-{{ section.id }} .tv__item:hover img {
    transform: scale(1.04);
  }
  #tisso-vision-{{ section.id }} .tv__plus {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 28px;
    height: 28px;
    background: #ffffff;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111111;
    padding: 0;
    z-index: 3;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    transition: transform 0.2s ease;
  }
  #tisso-vision-{{ section.id }} .tv__plus:hover {
    transform: scale(1.15);
  }
  /* ── Popup Overlay ── */
  #tisso-popup-{{ section.id }} {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
  }
  #tisso-popup-{{ section.id }}[hidden] {
    display: none;
  }
  @keyframes tvssFadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Popup Box ── */
  #tisso-popup-{{ section.id }} .tv__popup {
    background: #ffffff;
    border-radius: 0;
    width: 100%;
    max-width: 320px;
    position: relative;
    animation: tvssFadeUp 0.2s ease;
    box-sizing: border-box;
    padding: 20px;
  }

  /* ── Close Button ── */
  #tisso-popup-{{ section.id }} .tv__popup-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: #111;
    padding: 0;
    line-height: 1;
    z-index: 4;
  }

  /* ── Top Row: image + info ── */
  #tisso-popup-{{ section.id }} .tv__popup-top {
    display: flex;
    gap: 14px;
    margin-bottom: 18px;
  }

  /* ── Image ── */
  #tisso-popup-{{ section.id }} .tv__popup-img-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 140px;
    overflow: hidden;
    background: #e5e0d8;
  }
  #tisso-popup-{{ section.id }} .tv__popup-img {
    width: 120px;
    height: 140px;
    object-fit: cover;
    display: block;
  }

  /* ── Info (right of image) ── */
  #tisso-popup-{{ section.id }} .tv__popup-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-right: 20px;
  }
  #tisso-popup-{{ section.id }} .tv__popup-title {
    font-size: 15px;
    font-weight: 400;
    margin: 0 0 8px 0;
    color: #111111;
    line-height: 1.3;
    letter-spacing: 0;
  }
  #tisso-popup-{{ section.id }} .tv__popup-price {
    font-size: 15px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 10px 0;
    display: block;
  }
  #tisso-popup-{{ section.id }} .tv__popup-compare {
    font-size: 13px;
    color: #999999;
    text-decoration: line-through;
    margin-left: 6px;
  }
  #tisso-popup-{{ section.id }} .tv__popup-compare:empty {
    display: none;
  }
  #tisso-popup-{{ section.id }} .tv__popup-desc {
    font-size: 12px;
    color: #444444;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Divider ── */
  #tisso-popup-{{ section.id }} .tv__popup-divider {
    border: none;
    border-top: 1px solid #e8e8e8;
    margin: 0 0 16px 0;
  }

  /* ── Section Label ── */
  #tisso-popup-{{ section.id }} .tv__popup-label {
    font-size: 13px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 8px 0;
    display: block;
  }

  /* ── Color Swatches ── */
  #tisso-popup-{{ section.id }} .tv__popup-colors {
    display: flex;
    gap: 0;
    margin-bottom: 16px;
    border: 1px solid #cccccc;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn {
    flex: 1;
    padding: 10px 12px;
    background: #ffffff;
    border: none;
    border-right: 1px solid #cccccc;
    font-size: 13px;
    color: #111111;
    cursor: pointer;
    text-align: center;
    transition: background 0.15s;
    letter-spacing: 0.02em;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn:last-child {
    border-right: none;
  }
  #tisso-popup-{{ section.id }} .tv__color-btn.active,
  #tisso-popup-{{ section.id }} .tv__color-btn:hover {
    background: #f0f0f0;
  }

  /* ── Size Dropdown ── */
  #tisso-popup-{{ section.id }} .tv__popup-size-wrap {
    margin-bottom: 20px;
    position: relative;
  }
  #tisso-popup-{{ section.id }} .tv__size-select {
    width: 100%;
    padding: 10px 40px 10px 12px;
    border: 1px solid #cccccc;
    background: #ffffff;
    font-size: 13px;
    color: #111111;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    border-radius: 0;
    box-sizing: border-box;
    letter-spacing: 0.02em;
  }
  #tisso-popup-{{ section.id }} .tv__size-chevron {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #111;
  }

  /* ── Add to Cart Button ── */
  #tisso-popup-{{ section.id }} .tv__popup-atc {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    width: 100%;
    padding: 14px 20px;
    background: #111111;
    color: #ffffff;
    border: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    box-sizing: border-box;
    transition: background 0.2s;
  }
  #tisso-popup-{{ section.id }} .tv__popup-atc:hover {
    background: #333333;
  }
  #tisso-popup-{{ section.id }} .tv__popup-atc svg {
    flex-shrink: 0;
  }
  @media screen and (max-width: 749px) {
    #tisso-vision-{{ section.id }} .tv__title {
      font-size: 24px !important;
    }
    #tisso-vision-{{ section.id }} .tv__grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 3px !important;
    }
    #tisso-vision-{{ section.id }} .tv__item {
      aspect-ratio: 170 / 186 !important;
    }
    #tisso-vision-{{ section.id }} .tv__plus {
      width: 22px !important;
      height: 22px !important;
      bottom: 6px !important;
      right: 6px !important;
    }
    #tisso-vision-{{ section.id }} .tv__plus svg {
      width: 10px !important;
      height: 10px !important;
    }
  }
</style>

{%- liquid
  assign tv_collection = section.settings.collection
  assign tv_count = section.settings.product_count
-%}

<section id="tisso-vision-{{ section.id }}">
  <div class="tv__wrapper">

    {%- if section.settings.title != blank -%}
      <h2 class="tv__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="tv__grid">

      {%- if tv_collection != blank -%}
        {%- for product in tv_collection.products limit: tv_count -%}

          {%- assign p_img = product.featured_image -%}
          {%- assign p_img_url = '' -%}
          {%- if p_img != blank -%}
            {%- assign p_img_url = p_img | image_url: width: 900 -%}
            {%- assign p_img_url_sm = p_img | image_url: width: 400 -%}
            {%- assign p_img_url_md = p_img | image_url: width: 600 -%}
          {%- endif -%}

          {%- assign p_compare = '' -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign p_compare = product.compare_at_price | money -%}
          {%- endif -%}

          <div class="tv__item">
            {%- if p_img != blank -%}
              <img
                src="{{ p_img_url }}"
                srcset="{{ p_img_url_sm }} 400w, {{ p_img_url_md }} 600w, {{ p_img_url }} 900w"
                sizes="(max-width: 520px) 50vw, 25vw"
                alt="{{ p_img.alt | default: product.title | escape }}"
                width="{{ p_img.width }}"
                height="{{ p_img.height }}"
                loading="lazy"
              >
            {%- endif -%}

            <a href="{{ product.url }}" aria-label="{{ product.title | escape }}"></a>

            <button
              class="tv__plus"
              type="button"
              aria-label="Quick view {{ product.title | escape }}"
              data-title="{{ product.title | escape }}"
              data-price="{{ product.price | money }}"
              data-compare="{{ p_compare }}"
              data-url="{{ product.url }}"
              data-img="{{ p_img_url_sm }}"
              data-img-alt="{{ p_img.alt | default: product.title | escape }}"
            >
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="6" y1="0.5" x2="6" y2="11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="0.5" y1="6" x2="11.5" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

        {%- else -%}
          <p style="padding:20px;color:#999;">No products found in this collection.</p>
        {%- endfor -%}

      {%- else -%}
        <p style="padding:20px;color:#999;">Please select a collection in the theme editor.</p>
      {%- endif -%}

    </div>
  </div>
</section>

<div id="tisso-popup-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Product quick view" hidden>
  <div class="tv__popup">

    <!-- Close -->
    <button class="tv__popup-close" type="button" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Top row: image + info -->
    <div class="tv__popup-top">
      <div class="tv__popup-img-wrap">
        <img class="tv__popup-img" src="" alt="" width="120" height="140">
      </div>
      <div class="tv__popup-info">
        <p class="tv__popup-title"></p>
        <span class="tv__popup-price"></span>
        <p class="tv__popup-desc"></p>
      </div>
    </div>

    <hr class="tv__popup-divider">

    <!-- Color -->
    <span class="tv__popup-label">Color</span>
    <div class="tv__popup-colors" id="tvColorBtns-{{ section.id }}"></div>

    <!-- Size -->
    <span class="tv__popup-label">Size</span>
    <div class="tv__popup-size-wrap">
      <select class="tv__size-select" id="tvSizeSelect-{{ section.id }}">
        <option value="">Choose your size</option>
      </select>
      <svg class="tv__size-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polyline points="2,5 7,10 12,5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>

    <!-- Add to Cart -->
    <button class="tv__popup-atc" id="tvAtcBtn-{{ section.id }}" type="button">
      ADD TO CART
      <svg width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="0" y1="6" x2="18" y2="6" stroke="white" stroke-width="1.5"/>
        <polyline points="13,1 19,6 13,11" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </button>

  </div>
</div>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var section = document.getElementById('tisso-vision-' + sid);
  var overlay = document.getElementById('tisso-popup-' + sid);
  if (!section || !overlay) return;

  var popupImg     = overlay.querySelector('.tv__popup-img');
  var popupTitle   = overlay.querySelector('.tv__popup-title');
  var popupPrice   = overlay.querySelector('.tv__popup-price');
  var popupCompare = overlay.querySelector('.tv__popup-compare');
  var popupLink    = overlay.querySelector('.tv__popup-btn');
  var closeBtn     = overlay.querySelector('.tv__popup-close');

  function openPopup(btn) {
    popupTitle.textContent   = btn.dataset.title || '';
    popupPrice.textContent   = btn.dataset.price || '';
    popupCompare.textContent = btn.dataset.compare || '';
    popupLink.href           = btn.dataset.url || '#';
    if (btn.dataset.img) {
      popupImg.src           = btn.dataset.img;
      popupImg.alt           = btn.dataset.imgAlt || '';
      popupImg.style.display = 'block';
    } else {
      popupImg.style.display = 'none';
    }
    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closePopup() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  section.querySelectorAll('.tv__plus').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      openPopup(btn);
    });
  });

  closeBtn.addEventListener('click', closePopup);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closePopup();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closePopup();
  });
})();
</script>

{% schema %}
{
  "name": "Tisso Vision in the Wild",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Tisso Vision in the Wild"
    }
  ]
}
{% endschema %}
