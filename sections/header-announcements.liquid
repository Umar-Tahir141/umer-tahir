<style>
  #tisso-topbar-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  }

  #tisso-topbar-{{ section.id }} .tb__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: {{ section.settings.height }}px;
    gap: 16px;
  }

  #tisso-topbar-{{ section.id }} .tb__logo {
    font-size: {{ section.settings.logo_size }}px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    margin: 0;
    flex-shrink: 0;
    line-height: 1;
    font-family: inherit;
  }

  #tisso-topbar-{{ section.id }} .tb__message {
    font-size: {{ section.settings.message_size }}px;
    font-weight: 400;
    color: {{ section.settings.text_color }};
    margin: 0;
    text-align: center;
    flex: 1;
    line-height: 1.4;
    font-family: inherit;
  }

  #tisso-topbar-{{ section.id }} .tb__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 0 22px;
    height: 40px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
    white-space: nowrap;
    font-family: inherit;
  }

  #tisso-topbar-{{ section.id }} .tb__btn:hover {
    opacity: 0.9;
    transform: translateX(2px);
  }

  #tisso-topbar-{{ section.id }} .tb__btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    #tisso-topbar-{{ section.id }} .tb__inner {
      flex-wrap: wrap;
      justify-content: center;
      padding-top: 12px;
      padding-bottom: 12px;
      gap: 10px;
    }
    #tisso-topbar-{{ section.id }} .tb__logo,
    #tisso-topbar-{{ section.id }} .tb__message {
      flex: 1 1 100%;
      text-align: center;
    }
    #tisso-topbar-{{ section.id }} .tb__btn {
      width: 100%;
      justify-content: center;
      margin-top: 4px;
    }
  }
</style>

<div id="tisso-topbar-{{ section.id }}">
  <div class="tb__inner">
    {%- if section.settings.logo_text != blank -%}
      <p class="tb__logo">{{ section.settings.logo_text }}</p>
    {%- endif -%}

    {%- if section.settings.message != blank -%}
      <p class="tb__message">{{ section.settings.message }}</p>
    {%- endif -%}

    {%- if section.settings.btn_text != blank -%}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="tb__btn">
        <span>{{ section.settings.btn_text }}</span>
        <svg viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 1L17 6M17 6L12 11M17 6H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Tisso Top Bar",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Left — Logo / Brand"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "Logo font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Center — Message"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Message font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Right — Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#FFEB3B"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Bar background",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom border color",
      "default": "#E0E0E0"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Bottom border width",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "height",
      "label": "Bar height",
      "min": 36,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Tisso Top Bar"
    }
  ]
}
{% endschema %}